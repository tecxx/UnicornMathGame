<UserControl x:Class="MathGame.Views.BlockSelectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="BlockButton" TargetType="Button">
            <Setter Property="Margin"         Value="8"/>
            <Setter Property="Width"          Value="140"/>
            <Setter Property="Height"         Value="90"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="#DDD0F5"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="#40000000" BlurRadius="6" ShadowDepth="2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C8B8F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#B0A0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="BlockItemTemplate">
            <Button Style="{StaticResource BlockButton}"
                    Command="{Binding SelectCommand}">
                <StackPanel>
                    <TextBlock Text="{Binding Label}"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#4A2080"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Progress}"
                               FontSize="13" Foreground="#6B4BAA"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding StatusEmoji}"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="{Binding OperationLabel}"
                   FontSize="36" FontWeight="Bold"
                   Foreground="#5B2D8E"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,4"/>

        <TextBlock Grid.Row="1"
                   Text="Pick a block to practise:"
                   FontSize="16" Foreground="#7B5FBF"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- 5×2 block grid -->
        <ItemsControl Grid.Row="2"
                      ItemsSource="{Binding Blocks}"
                      ItemTemplate="{StaticResource BlockItemTemplate}"
                      HorizontalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="2" Columns="5"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <!-- Back button -->
        <Button Grid.Row="3"
                Content="← Back to menu"
                Command="{Binding BackCommand}"
                HorizontalAlignment="Left"
                Margin="0,20,0,0"
                Padding="16,8"
                FontSize="14"
                Background="#9B59B6"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </Grid>
</UserControl>
