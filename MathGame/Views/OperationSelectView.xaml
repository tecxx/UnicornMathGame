<UserControl x:Class="MathGame.Views.OperationSelectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Rounded pill template for difficulty buttons -->
        <ControlTemplate x:Key="RoundedButton" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="{TemplateBinding Tag}"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect Color="#50000000" BlurRadius="10" ShadowDepth="3"/>
                </Border.Effect>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.85"/></Trigger>
                <Trigger Property="IsPressed"   Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.65"/></Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Difficulty pill style -->
        <Style x:Key="DiffBtn" TargetType="Button">
            <Setter Property="Width"           Value="200"/>
            <Setter Property="Height"          Value="158"/>
            <Setter Property="Margin"          Value="16,0"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Tag"             Value="20"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template"        Value="{StaticResource RoundedButton}"/>
        </Style>

        <!-- Corner operation button style (transparent, full quadrant clickable) -->
        <ControlTemplate x:Key="CornerOpTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="Transparent">
                <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#44FFFFFF"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Leaderboard row style -->
        <Style x:Key="LbName" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,1,0,0"/>
        </Style>
        <Style x:Key="LbTime" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#FFD700"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="4,1,0,0"/>
        </Style>

    </UserControl.Resources>

    <Grid>

        <!-- ════════════════════════════════════════════════════════════
             PHASE 1 — Difficulty selector (shown until difficulty picked)
             ════════════════════════════════════════════════════════════ -->
        <Grid x:Name="DifficultyPanel">

            <!-- Gradient background -->
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,1">
                        <GradientStop Color="#1A0040" Offset="0"/>
                        <GradientStop Color="#2D0870" Offset="0.5"/>
                        <GradientStop Color="#1A0050" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Stars -->
            <Canvas>
                <Ellipse Canvas.Left="80"  Canvas.Top="40"  Width="3" Height="3" Fill="White" Opacity="0.6"/>
                <Ellipse Canvas.Left="200" Canvas.Top="70"  Width="2" Height="2" Fill="White" Opacity="0.5"/>
                <Ellipse Canvas.Left="350" Canvas.Top="30"  Width="3" Height="3" Fill="White" Opacity="0.7"/>
                <Ellipse Canvas.Left="500" Canvas.Top="80"  Width="2" Height="2" Fill="White" Opacity="0.5"/>
                <Ellipse Canvas.Left="650" Canvas.Top="25"  Width="3" Height="3" Fill="White" Opacity="0.6"/>
                <Ellipse Canvas.Left="800" Canvas.Top="60"  Width="2" Height="2" Fill="White" Opacity="0.5"/>
                <Ellipse Canvas.Left="950" Canvas.Top="35"  Width="3" Height="3" Fill="White" Opacity="0.7"/>
                <Ellipse Canvas.Left="1100" Canvas.Top="55" Width="2" Height="2" Fill="White" Opacity="0.5"/>
                <Ellipse Canvas.Left="1220" Canvas.Top="30" Width="3" Height="3" Fill="White" Opacity="0.6"/>
                <Ellipse Canvas.Left="130" Canvas.Top="200" Width="2" Height="2" Fill="White" Opacity="0.4"/>
                <Ellipse Canvas.Left="450" Canvas.Top="180" Width="3" Height="3" Fill="White" Opacity="0.5"/>
                <Ellipse Canvas.Left="780" Canvas.Top="190" Width="2" Height="2" Fill="White" Opacity="0.4"/>
                <Ellipse Canvas.Left="1050" Canvas.Top="170" Width="3" Height="3" Fill="White" Opacity="0.5"/>
            </Canvas>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <!-- Title -->
                <TextBlock Text="Math Adventure!" FontSize="60" FontWeight="Black"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#AA8040FF" BlurRadius="20" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>

                <TextBlock Text="Choose your difficulty to begin!" FontSize="20" Foreground="#C0A0FF"
                           HorizontalAlignment="Center" Margin="0,0,0,50"/>

                <!-- Three big difficulty buttons -->
                <WrapPanel HorizontalAlignment="Center">

                    <!-- Easy -->
                    <Button Command="{Binding SelectEasyCommand}" Background="#2E8B2E"
                            Style="{StaticResource DiffBtn}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="🌱" FontSize="34" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Easy" FontSize="22" FontWeight="Black" HorizontalAlignment="Center"/>
                            <TextBlock Text="20 questions" FontSize="12" HorizontalAlignment="Center" Opacity="0.85" Margin="0,3,0,0"/>
                            <TextBlock Text="Numbers up to 10" FontSize="11" HorizontalAlignment="Center" Opacity="0.75"/>
                            <TextBlock Text="20 puzzle pieces" FontSize="11" HorizontalAlignment="Center" Opacity="0.75" Foreground="#90FF90"/>
                        </StackPanel>
                    </Button>

                    <!-- Medium -->
                    <Button Command="{Binding SelectMediumCommand}" Background="#D4830A"
                            Style="{StaticResource DiffBtn}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="⚡" FontSize="34" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Medium" FontSize="22" FontWeight="Black" HorizontalAlignment="Center"/>
                            <TextBlock Text="50 questions" FontSize="12" HorizontalAlignment="Center" Opacity="0.85" Margin="0,3,0,0"/>
                            <TextBlock Text="Numbers up to 20" FontSize="11" HorizontalAlignment="Center" Opacity="0.75"/>
                            <TextBlock Text="40 puzzle pieces" FontSize="11" HorizontalAlignment="Center" Opacity="0.75" Foreground="#FFD080"/>
                        </StackPanel>
                    </Button>

                    <!-- Hard -->
                    <Button Command="{Binding SelectHardCommand}" Background="#992222"
                            Style="{StaticResource DiffBtn}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="🐉" FontSize="34" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Hard" FontSize="22" FontWeight="Black" HorizontalAlignment="Center"/>
                            <TextBlock Text="100 questions" FontSize="12" HorizontalAlignment="Center" Opacity="0.85" Margin="0,3,0,0"/>
                            <TextBlock Text="Numbers up to 50" FontSize="11" HorizontalAlignment="Center" Opacity="0.75"/>
                            <TextBlock Text="60 puzzle pieces" FontSize="11" HorizontalAlignment="Center" Opacity="0.75" Foreground="#FF9090"/>
                        </StackPanel>
                    </Button>

                </WrapPanel>


            </StackPanel>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════
             PHASE 2 — Game type selection with puzzle art + leaderboard
             ════════════════════════════════════════════════════════════ -->
        <Grid x:Name="GamePanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><!-- Leaderboard strip -->
                <RowDefinition Height="*"/>   <!-- Top animal row -->
                <RowDefinition Height="*"/>   <!-- Bottom animal row -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Leaderboard strip (spans all columns) ── -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Padding="12,10" Panel.ZIndex="10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#E8100030" Offset="0"/>
                        <GradientStop Color="#E8200060" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Trophy icon + label -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="🏆" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="Best Times" FontSize="10" Foreground="#FFD700"
                                   FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Addition column -->
                    <StackPanel Grid.Column="1" Margin="6,0">
                        <TextBlock FontSize="13" FontWeight="Black" Foreground="#F5A623" Margin="0,0,0,3">
                            + Addition
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding AdditionBoard}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Rank}" Style="{StaticResource LbTime}" MinWidth="18"/>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource LbName}" MaxWidth="90" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Time}" Style="{StaticResource LbTime}" Margin="6,1,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Subtraction column -->
                    <StackPanel Grid.Column="2" Margin="6,0">
                        <TextBlock FontSize="13" FontWeight="Black" Foreground="#4A90D9" Margin="0,0,0,3">
                            − Subtraction
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding SubtractionBoard}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Rank}" Style="{StaticResource LbTime}" MinWidth="18"/>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource LbName}" MaxWidth="90" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Time}" Style="{StaticResource LbTime}" Margin="6,1,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Multiplication column -->
                    <StackPanel Grid.Column="3" Margin="6,0">
                        <TextBlock FontSize="13" FontWeight="Black" Foreground="#7ED321" Margin="0,0,0,3">
                            × Multiply
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding MultiplyBoard}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Rank}" Style="{StaticResource LbTime}" MinWidth="18"/>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource LbName}" MaxWidth="90" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Time}" Style="{StaticResource LbTime}" Margin="6,1,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Division column -->
                    <StackPanel Grid.Column="4" Margin="6,0">
                        <TextBlock FontSize="13" FontWeight="Black" Foreground="#C080FF" Margin="0,0,0,3">
                            ÷ Division
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding DivisionBoard}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Rank}" Style="{StaticResource LbTime}" MinWidth="18"/>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource LbName}" MaxWidth="90" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Time}" Style="{StaticResource LbTime}" Margin="6,1,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Reset button -->
                    <Button Grid.Column="5" Command="{Binding ResetAllCommand}"
                            Template="{StaticResource RoundedButton}"
                            Background="#99660000" Tag="8"
                            Foreground="White" FontSize="10" FontWeight="Bold"
                            Padding="10,6" BorderThickness="0"
                            VerticalAlignment="Center" Margin="14,0,0,0"
                            Cursor="Hand"
                            ToolTip="Reset all puzzle progress">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="↺" FontSize="18" HorizontalAlignment="Center" LineHeight="20"/>
                            <TextBlock Text="Reset" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </Grid>
            </Border>

            <!-- ════ TOP-LEFT: Horse / Addition + ════ -->
            <Button Grid.Row="1" Grid.Column="0"
                    Command="{Binding SelectAdditionCommand}"
                    Template="{StaticResource CornerOpTemplate}"
                    Cursor="Hand">
                <Grid ClipToBounds="True">
                    <!-- Horse image: drop Assets/horse.png (or .bmp) here -->
                    <Image Source="{Binding HorseImage}" Stretch="UniformToFill"/>

                    <!-- Puzzle piece overlay -->
                    <ItemsControl ItemsSource="{Binding HorsePieces}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="5"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FA060606"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRevealed}" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Hover highlight frame -->
                    <Border BorderThickness="4" BorderBrush="#88F5A623" CornerRadius="0"/>

                    <!-- Operation badge (top-left corner) -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                            Background="#DDF5A623" CornerRadius="0,0,16,0"
                            Padding="14,8">
                        <Border.Effect>
                            <DropShadowEffect Color="#80000000" BlurRadius="8" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="+" FontSize="44" FontWeight="Black" Foreground="White" LineHeight="44"/>
                            <TextBlock Text="Addition" FontSize="13" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <!-- Progress bottom-right -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Background="#AA000000" CornerRadius="8,0,0,0" Padding="8,4">
                        <TextBlock Text="{Binding HorseProgress}" Foreground="#FFD700"
                                   FontSize="11" FontWeight="Bold"/>
                    </Border>

                    <!-- Complete overlay -->
                    <Grid x:Name="HorseCompleteOverlay" Visibility="Collapsed" IsHitTestVisible="False">
                        <Border x:Name="HorseGoldBorder" BorderThickness="8">
                            <Border.BorderBrush><SolidColorBrush Color="#FFD700"/></Border.BorderBrush>
                            <Border.Effect><DropShadowEffect Color="#FFD700" BlurRadius="28" ShadowDepth="0"/></Border.Effect>
                        </Border>
                        <Border Background="#CC000000" HorizontalAlignment="Center" VerticalAlignment="Center"
                                CornerRadius="18" Padding="30,16" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="HorseCompleteScale" ScaleX="0" ScaleY="0"/>
                            </Border.RenderTransform>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="⭐ COMPLETE! ⭐" FontSize="26" FontWeight="Black"
                                           Foreground="#FFD700" HorizontalAlignment="Center"/>
                                <TextBlock Text="All pieces unlocked!" FontSize="12" Foreground="#DDD"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Button>

            <!-- ════ TOP-RIGHT: Dolphin / Subtraction − ════ -->
            <Button Grid.Row="1" Grid.Column="1"
                    Command="{Binding SelectSubtractionCommand}"
                    Template="{StaticResource CornerOpTemplate}"
                    Cursor="Hand">
                <Grid ClipToBounds="True">
                    <!-- Dolphin image: drop Assets/dolphin.png (or .bmp) here -->
                    <Image Source="{Binding DolphinImage}" Stretch="UniformToFill"/>

                    <!-- Puzzle piece overlay -->
                    <ItemsControl ItemsSource="{Binding DolphinPieces}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Columns="5"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FA060606"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRevealed}" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Hover highlight -->
                    <Border BorderThickness="4" BorderBrush="#884A90D9" CornerRadius="0"/>

                    <!-- Operation badge (top-right) -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="#DD4A90D9" CornerRadius="0,0,0,16"
                            Padding="14,8">
                        <Border.Effect>
                            <DropShadowEffect Color="#80000000" BlurRadius="8" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="−" FontSize="44" FontWeight="Black" Foreground="White" LineHeight="44"/>
                            <TextBlock Text="Subtraction" FontSize="13" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <!-- Progress -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Background="#AA000000" CornerRadius="0,8,0,0" Padding="8,4">
                        <TextBlock Text="{Binding DolphinProgress}" Foreground="#FFD700"
                                   FontSize="11" FontWeight="Bold"/>
                    </Border>

                    <!-- Complete overlay -->
                    <Grid x:Name="DolphinCompleteOverlay" Visibility="Collapsed" IsHitTestVisible="False">
                        <Border x:Name="DolphinGoldBorder" BorderThickness="8">
                            <Border.BorderBrush><SolidColorBrush Color="#FFD700"/></Border.BorderBrush>
                            <Border.Effect><DropShadowEffect Color="#FFD700" BlurRadius="28" ShadowDepth="0"/></Border.Effect>
                        </Border>
                        <Border Background="#CC000000" HorizontalAlignment="Center" VerticalAlignment="Center"
                                CornerRadius="18" Padding="30,16" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="DolphinCompleteScale" ScaleX="0" ScaleY="0"/>
                            </Border.RenderTransform>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="⭐ COMPLETE! ⭐" FontSize="26" FontWeight="Black"
                                           Foreground="#FFD700" HorizontalAlignment="Center"/>
                                <TextBlock Text="All pieces unlocked!" FontSize="12" Foreground="#DDD"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Button>

            <!-- ════ BOTTOM-LEFT: Tiger / Multiplication × ════ -->
            <Button Grid.Row="2" Grid.Column="0"
                    Command="{Binding SelectMultiplicationCommand}"
                    Template="{StaticResource CornerOpTemplate}"
                    Cursor="Hand">
                <Grid ClipToBounds="True">
                    <!-- Tiger image: drop Assets/tiger.png (or .bmp) here -->
                    <Image Source="{Binding TigerImage}" Stretch="UniformToFill"/>

                    <!-- Puzzle piece overlay -->
                    <ItemsControl ItemsSource="{Binding TigerPieces}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Columns="5"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FA060606"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRevealed}" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Hover highlight -->
                    <Border BorderThickness="4" BorderBrush="#887ED321" CornerRadius="0"/>

                    <!-- Operation badge (bottom-left) -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Background="#DD7ED321" CornerRadius="0,16,0,0"
                            Padding="14,8">
                        <Border.Effect>
                            <DropShadowEffect Color="#80000000" BlurRadius="8" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="×" FontSize="44" FontWeight="Black" Foreground="White" LineHeight="44"/>
                            <TextBlock Text="Multiplication" FontSize="13" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <!-- Progress -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="#AA000000" CornerRadius="0,0,0,8" Padding="8,4">
                        <TextBlock Text="{Binding TigerProgress}" Foreground="#FFD700"
                                   FontSize="11" FontWeight="Bold"/>
                    </Border>

                    <!-- Complete overlay -->
                    <Grid x:Name="TigerCompleteOverlay" Visibility="Collapsed" IsHitTestVisible="False">
                        <Border x:Name="TigerGoldBorder" BorderThickness="8">
                            <Border.BorderBrush><SolidColorBrush Color="#FFD700"/></Border.BorderBrush>
                            <Border.Effect><DropShadowEffect Color="#FFD700" BlurRadius="28" ShadowDepth="0"/></Border.Effect>
                        </Border>
                        <Border Background="#CC000000" HorizontalAlignment="Center" VerticalAlignment="Center"
                                CornerRadius="18" Padding="30,16" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="TigerCompleteScale" ScaleX="0" ScaleY="0"/>
                            </Border.RenderTransform>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="⭐ COMPLETE! ⭐" FontSize="26" FontWeight="Black"
                                           Foreground="#FFD700" HorizontalAlignment="Center"/>
                                <TextBlock Text="All pieces unlocked!" FontSize="12" Foreground="#DDD"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Button>

            <!-- ════ BOTTOM-RIGHT: Dragon / Division ÷ ════ -->
            <Button Grid.Row="2" Grid.Column="1"
                    Command="{Binding SelectDivisionCommand}"
                    Template="{StaticResource CornerOpTemplate}"
                    Cursor="Hand">
                <Grid ClipToBounds="True">
                    <!-- Dragon image: drop Assets/dragon.png (or .bmp) here -->
                    <Image Source="{Binding DragonImage}" Stretch="UniformToFill"/>

                    <!-- Puzzle piece overlay -->
                    <ItemsControl ItemsSource="{Binding DragonPieces}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Columns="5"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FA060606"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRevealed}" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Hover highlight -->
                    <Border BorderThickness="4" BorderBrush="#889B59B6" CornerRadius="0"/>

                    <!-- Operation badge (bottom-right) -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Background="#DD9B59B6" CornerRadius="16,0,0,0"
                            Padding="14,8">
                        <Border.Effect>
                            <DropShadowEffect Color="#80000000" BlurRadius="8" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="÷" FontSize="44" FontWeight="Black" Foreground="White" LineHeight="44"/>
                            <TextBlock Text="Division" FontSize="13" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <!-- Progress -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                            Background="#AA000000" CornerRadius="0,0,8,0" Padding="8,4">
                        <TextBlock Text="{Binding DragonProgress}" Foreground="#FFD700"
                                   FontSize="11" FontWeight="Bold"/>
                    </Border>

                    <!-- Complete overlay -->
                    <Grid x:Name="DragonCompleteOverlay" Visibility="Collapsed" IsHitTestVisible="False">
                        <Border x:Name="DragonGoldBorder" BorderThickness="8">
                            <Border.BorderBrush><SolidColorBrush Color="#FFD700"/></Border.BorderBrush>
                            <Border.Effect><DropShadowEffect Color="#FFD700" BlurRadius="28" ShadowDepth="0"/></Border.Effect>
                        </Border>
                        <Border Background="#CC000000" HorizontalAlignment="Center" VerticalAlignment="Center"
