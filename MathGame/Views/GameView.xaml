<UserControl x:Class="MathGame.Views.GameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Pill button used for Back and Check -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                            <Trigger Property="IsPressed"   Value="True"><Setter Property="Opacity" Value="0.70"/></Trigger>
                            <Trigger Property="IsEnabled"   Value="False"><Setter Property="Opacity" Value="0.35"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>

        <!-- ═══ Main game layout ═══ -->
        <DockPanel Margin="16,12,16,12">

            <!-- Top bar -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="← Back"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource PillButton}"
                        Background="#9B59B6"
                        FontSize="13"
                        Padding="12,6"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding OperationLabel}"
                           FontSize="24" FontWeight="Bold"
                           Foreground="#5B2D8E"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- ── Timer display ── -->
                <Border Grid.Column="2"
                        Background="#EEE4FF"
                        CornerRadius="10"
                        Padding="12,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏱"
                                   FontSize="15"
                                   VerticalAlignment="Center"
                                   Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding ElapsedTime}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#5B2D8E"
                                   VerticalAlignment="Center"
                                   MinWidth="46"
                                   TextAlignment="Right"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ Unicorn progress path ═══ -->
            <Border DockPanel.Dock="Top"
                    Height="92" Margin="0,4,0,6"
                    CornerRadius="10" ClipToBounds="True">
                <Viewbox Stretch="Fill">
                    <Canvas Width="1000" Height="90">

                        <!-- ── Sky ── -->
                        <Rectangle Width="1000" Height="90">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#A0D0F0" Offset="0"/>
                                    <GradientStop Color="#D8F0FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- ── Rainbow (behind clouds &amp; mountains) ── -->
                        <Ellipse Canvas.Left="255" Canvas.Top="-5"  Width="496" Height="120" Stroke="#FF6040" StrokeThickness="7" Fill="Transparent" Opacity="0.45"/>
                        <Ellipse Canvas.Left="267" Canvas.Top="5"   Width="472" Height="100" Stroke="#FF9820" StrokeThickness="7" Fill="Transparent" Opacity="0.45"/>
                        <Ellipse Canvas.Left="279" Canvas.Top="14"  Width="448" Height="82"  Stroke="#FFE040" StrokeThickness="7" Fill="Transparent" Opacity="0.45"/>
                        <Ellipse Canvas.Left="291" Canvas.Top="23"  Width="424" Height="64"  Stroke="#50D040" StrokeThickness="7" Fill="Transparent" Opacity="0.45"/>
                        <Ellipse Canvas.Left="303" Canvas.Top="31"  Width="400" Height="48"  Stroke="#40A8FF" StrokeThickness="7" Fill="Transparent" Opacity="0.45"/>
                        <Ellipse Canvas.Left="315" Canvas.Top="39"  Width="376" Height="32"  Stroke="#9040FF" StrokeThickness="7" Fill="Transparent" Opacity="0.45"/>

                        <!-- ── Clouds ── -->
                        <!-- Cloud 1 -->
                        <Ellipse Canvas.Left="72"  Canvas.Top="9"  Width="52" Height="17" Fill="White" Opacity="0.88"/>
                        <Ellipse Canvas.Left="86"  Canvas.Top="5"  Width="44" Height="21" Fill="White" Opacity="0.88"/>
                        <Ellipse Canvas.Left="108" Canvas.Top="9"  Width="44" Height="16" Fill="White" Opacity="0.88"/>
                        <!-- Cloud 2 -->
                        <Ellipse Canvas.Left="700" Canvas.Top="7"  Width="57" Height="18" Fill="White" Opacity="0.82"/>
                        <Ellipse Canvas.Left="717" Canvas.Top="3"  Width="44" Height="22" Fill="White" Opacity="0.82"/>
                        <Ellipse Canvas.Left="740" Canvas.Top="7"  Width="42" Height="16" Fill="White" Opacity="0.82"/>
                        <!-- Cloud 3 (small, far right) -->
                        <Ellipse Canvas.Left="870" Canvas.Top="11" Width="46" Height="15" Fill="White" Opacity="0.80"/>
                        <Ellipse Canvas.Left="883" Canvas.Top="7"  Width="38" Height="18" Fill="White" Opacity="0.80"/>
                        <Ellipse Canvas.Left="902" Canvas.Top="11" Width="36" Height="14" Fill="White" Opacity="0.80"/>

                        <!-- ── Mountains ── -->
                        <!-- Mountain A -->
                        <Polygon Points="460,70 578,13 696,70"  Fill="#8AAAC5"/>
                        <Polygon Points="561,19  578,13 595,19" Fill="White" Opacity="0.80"/>
                        <!-- Mountain B (tallest) -->
                        <Polygon Points="624,70 754,2  884,70"  Fill="#6D8FB5"/>
                        <Polygon Points="737,10 754,2  771,10"  Fill="White" Opacity="0.88"/>
                        <!-- Mountain C (right) -->
                        <Polygon Points="862,70 944,19 1010,70" Fill="#8AAAC2"/>
                        <Polygon Points="928,25  944,19 960,25" Fill="White" Opacity="0.78"/>

                        <!-- ── Near hills (in front of mountain bases) ── -->
                        <Ellipse Canvas.Left="-40" Canvas.Top="42" Width="248" Height="46" Fill="#54B030"/>
                        <Ellipse Canvas.Left="183" Canvas.Top="48" Width="210" Height="38" Fill="#60BF3C"/>
                        <Ellipse Canvas.Left="878" Canvas.Top="50" Width="188" Height="38" Fill="#54B030"/>

                        <!-- ── Lake ── -->
                        <Ellipse Canvas.Left="349" Canvas.Top="59" Width="164" Height="20" Fill="#3A8EE0" Opacity="0.82"/>
                        <Ellipse Canvas.Left="359" Canvas.Top="61" Width="56"  Height="6"  Fill="White"  Opacity="0.32"/>

                        <!-- ── Ground ── -->
                        <Rectangle Canvas.Left="0" Canvas.Top="65" Width="1000" Height="25" Fill="#6BBD43"/>

                        <!-- ── Dirt path ── -->
                        <Rectangle Canvas.Left="0" Canvas.Top="67" Width="1000" Height="7" Fill="#C4955A"/>
                        <Rectangle Canvas.Left="0" Canvas.Top="68" Width="1000" Height="3" Fill="#D8A86A" Opacity="0.40"/>

                        <!-- ── Pine trees (trunk + 3 green layers each) ── -->
                        <!-- Tree 1  cx=62 -->
                        <Rectangle Canvas.Left="59"  Canvas.Top="56" Width="6" Height="11" Fill="#7B5232"/>
                        <Polygon Points="44,66  62,40  80,66"  Fill="#2A8638"/>
                        <Polygon Points="49,54  62,33  75,54"  Fill="#369E44"/>
                        <Polygon Points="54,45  62,29  70,45"  Fill="#3DB84E"/>
                        <!-- Tree 2  cx=163 -->
                        <Rectangle Canvas.Left="160" Canvas.Top="56" Width="6" Height="11" Fill="#7B5232"/>
                        <Polygon Points="145,66 163,40 181,66" Fill="#2A8638"/>
                        <Polygon Points="150,54 163,33 176,54" Fill="#369E44"/>
                        <Polygon Points="155,45 163,29 171,45" Fill="#3DB84E"/>
                        <!-- Tree 3  cx=308 (left shore of lake) -->
                        <Rectangle Canvas.Left="305" Canvas.Top="56" Width="6" Height="11" Fill="#7B5232"/>
                        <Polygon Points="290,66 308,40 326,66" Fill="#2A8638"/>
                        <Polygon Points="295,54 308,33 321,54" Fill="#369E44"/>
                        <Polygon Points="300,45 308,29 316,45" Fill="#3DB84E"/>
                        <!-- Tree 4  cx=721 -->
                        <Rectangle Canvas.Left="718" Canvas.Top="56" Width="6" Height="11" Fill="#7B5232"/>
                        <Polygon Points="703,66 721,40 739,66" Fill="#2A8638"/>
                        <Polygon Points="708,54 721,33 734,54" Fill="#369E44"/>
                        <Polygon Points="713,45 721,29 729,45" Fill="#3DB84E"/>
                        <!-- Tree 5  cx=843 -->
                        <Rectangle Canvas.Left="840" Canvas.Top="56" Width="6" Height="11" Fill="#7B5232"/>
                        <Polygon Points="825,66 843,40 861,66" Fill="#2A8638"/>
                        <Polygon Points="830,54 843,33 856,54" Fill="#369E44"/>
                        <Polygon Points="835,45 843,29 851,45" Fill="#3DB84E"/>

                        <!-- ── House (start / left) ── -->
                        <Rectangle Canvas.Left="29"  Canvas.Top="38" Width="5"  Height="16" Fill="#C07860"/><!-- chimney -->
                        <Rectangle Canvas.Left="8"   Canvas.Top="51" Width="32" Height="17" Fill="#F2E4C8"/><!-- walls -->
                        <Rectangle Canvas.Left="8"   Canvas.Top="51" Width="32" Height="17" Fill="Transparent" Stroke="#C0A070" StrokeThickness="0.5"/>
                        <Polygon   Points="5,52 24,40 43,52"           Fill="#C03838"/><!-- roof -->
                        <Rectangle Canvas.Left="17"  Canvas.Top="57" Width="8"  Height="11" Fill="#9B7040"/><!-- door -->
                        <Rectangle Canvas.Left="10"  Canvas.Top="53" Width="7"  Height="7"  Fill="#B8E0FF"/><!-- window -->
                        <Rectangle Canvas.Left="10"  Canvas.Top="53" Width="7"  Height="7"  Fill="Transparent" Stroke="#9B7040" StrokeThickness="0.5"/>

                        <!-- ── Castle (goal / right) ── -->
                        <!-- Left tower -->
                        <Rectangle Canvas.Left="953" Canvas.Top="34" Width="14" Height="33" Fill="#B8A8D0"/>
                        <Rectangle Canvas.Left="951" Canvas.Top="30" Width="5"  Height="6"  Fill="#A898C0"/><!-- battlement -->
                        <Rectangle Canvas.Left="960" Canvas.Top="30" Width="5"  Height="6"  Fill="#A898C0"/>
                        <!-- Right tower -->
                        <Rectangle Canvas.Left="978" Canvas.Top="37" Width="12" Height="30" Fill="#B8A8D0"/>
                        <Rectangle Canvas.Left="976" Canvas.Top="33" Width="5"  Height="5"  Fill="#A898C0"/>
                        <Rectangle Canvas.Left="984" Canvas.Top="33" Width="5"  Height="5"  Fill="#A898C0"/>
                        <!-- Connecting wall -->
                        <Rectangle Canvas.Left="963" Canvas.Top="44" Width="18" Height="23" Fill="#C8B8E0"/>
                        <!-- Gate -->
                        <Ellipse   Canvas.Left="969" Canvas.Top="53" Width="10" Height="10" Fill="#4428A0"/>
                        <Rectangle Canvas.Left="969" Canvas.Top="58" Width="10" Height="9"  Fill="#4428A0"/>
                        <!-- Flag -->
                        <Line X1="960" Y1="28" X2="960" Y2="38" Stroke="#806090" StrokeThickness="1.5"/>
                        <Polygon Points="960,28 970,31 960,34" Fill="#CC40CC"/>

                        <!-- ── Pink unicorn (one step per correct answer) ── -->
                        <!-- Inner Canvas anchors everything to UnicornX; children may
                             intentionally exceed its bounds (horn above, tail to left). -->
                        <Canvas Canvas.Left="{Binding UnicornX}" Canvas.Top="42"
                                Width="28" Height="25" Panel.ZIndex="100">

                            <!-- Tail (left of body, three pink blobs) -->
                            <Ellipse Canvas.Left="-1" Canvas.Top="9"  Width="6" Height="4" Fill="#E040B0"/>
                            <Ellipse Canvas.Left="-2" Canvas.Top="12" Width="5" Height="5" Fill="#C02090"/>
                            <Ellipse Canvas.Left="-1" Canvas.Top="16" Width="5" Height="4" Fill="#E040B0"/>

                            <!-- Body -->
                            <Ellipse Canvas.Left="2"  Canvas.Top="9"  Width="19" Height="11" Fill="#FFB6C8"/>

                            <!-- Neck -->
                            <Polygon Points="18,20 23,20 22,9 19,9" Fill="#FFB6C8"/>

                            <!-- Head -->
                            <Ellipse Canvas.Left="17" Canvas.Top="3"  Width="11" Height="9"  Fill="#FFB6C8"/>

                            <!-- Ear -->
                            <Polygon Points="20,3 23,3 21.5,0"   Fill="#FFB6C8"/>
                            <Polygon Points="20.5,3 22.5,3 21.5,1.2" Fill="#F090B0"/>

                            <!-- Horn (gold, pointing up) -->
                            <Polygon Points="22,3 25,3 23.5,-4"  Fill="#FFD700"/>
                            <Polygon Points="23,3 24.2,3 23.5,-2" Fill="#FFF5A0" Opacity="0.75"/>

                            <!-- Mane (hot-pink blobs down back of head/neck) -->
                            <Ellipse Canvas.Left="15" Canvas.Top="2"  Width="5" Height="5" Fill="#E040B0"/>
                            <Ellipse Canvas.Left="14" Canvas.Top="6"  Width="5" Height="5" Fill="#C02090"/>
                            <Ellipse Canvas.Left="14" Canvas.Top="10" Width="4" Height="5" Fill="#E040B0"/>

                            <!-- Legs (four, with rounded hooves) -->
                            <Rectangle Canvas.Left="4"  Canvas.Top="18" Width="3" Height="5" Fill="#F8A0BC" RadiusX="1" RadiusY="1"/>
                            <Rectangle Canvas.Left="8"  Canvas.Top="18" Width="3" Height="5" Fill="#F8A0BC" RadiusX="1" RadiusY="1"/>
                            <Rectangle Canvas.Left="14" Canvas.Top="18" Width="3" Height="5" Fill="#F8A0BC" RadiusX="1" RadiusY="1"/>
                            <Rectangle Canvas.Left="18" Canvas.Top="18" Width="3" Height="5" Fill="#F8A0BC" RadiusX="1" RadiusY="1"/>

                            <!-- Hooves (darker purple-pink) -->
                            <Rectangle Canvas.Left="4"  Canvas.Top="22" Width="3" Height="3" Fill="#B030A0" RadiusX="1" RadiusY="1"/>
                            <Rectangle Canvas.Left="8"  Canvas.Top="22" Width="3" Height="3" Fill="#B030A0" RadiusX="1" RadiusY="1"/>
                            <Rectangle Canvas.Left="14" Canvas.Top="22" Width="3" Height="3" Fill="#B030A0" RadiusX="1" RadiusY="1"/>
                            <Rectangle Canvas.Left="18" Canvas.Top="22" Width="3" Height="3" Fill="#B030A0" RadiusX="1" RadiusY="1"/>

                            <!-- Eye + shine -->
                            <Ellipse Canvas.Left="25"   Canvas.Top="6"   Width="2.5" Height="2.5" Fill="#222222"/>
                            <Ellipse Canvas.Left="25.8" Canvas.Top="6.3" Width="1"   Height="1"   Fill="White"/>

                        </Canvas>

                    </Canvas>
                </Viewbox>
            </Border>

            <!-- Input bar at the bottom -->
            <Border DockPanel.Dock="Bottom"
                    Background="#EEE4FF"
                    CornerRadius="12"
                    Padding="12,8"
                    Margin="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Answer:"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="#5B2D8E"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <TextBox Grid.Column="1"
                             x:Name="AnswerBox"
                             Text="{Binding PlayerInput, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="20" FontWeight="Bold"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             Height="38"
                             BorderBrush="#9B59B6"
                             BorderThickness="2"
                             Padding="4">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SubmitCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="2"
                            Content="Check ✓"
                            Command="{Binding SubmitCommand}"
                            Style="{StaticResource PillButton}"
                            Background="#5CB85C"
                            FontSize="14"
                            Padding="16,7"
                            Margin="10,0,0,0"/>

                    <TextBlock Grid.Column="3"
                               Text="{Binding FeedbackMessage}"
                               FontSize="15" FontWeight="Bold"
                               Foreground="#333"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"/>
                </Grid>
            </Border>

            <!-- ═══ Question grid — 10 columns (blocks) × 10 rows ═══ -->
            <!-- No horizontal scroll: columns share available width via UniformGrid -->
            <ItemsControl ItemsSource="{Binding Columns}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>

                    <!-- One block column -->
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Grid allows the unicorn overlay to sit on top of the questions -->
                            <Grid Margin="2,0">

                                <StackPanel>
                                    <!-- Column header: block number -->
                                    <Border Background="#C8A8F0"
                                            CornerRadius="6,6,0,0"
                                            Height="28"
                                            Margin="0,0,0,1">
                                        <TextBlock Text="{Binding Header}"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="#3D1A70"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- 10 question cells -->
                                    <ItemsControl ItemsSource="{Binding Questions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding Background}"
                                                        Height="30"
                                                        Margin="0,1,0,0"
                                                        CornerRadius="4">
                                                    <TextBlock Text="{Binding DisplayText}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{Binding Foreground}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Per-column unicorn overlay — shown when all 10 are correct -->
                                <Border Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"
                                        Background="#DD7B4FA8"
                                        CornerRadius="6"
                                        Margin="0,29,0,0">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                                        <!-- Drawn pink unicorn (scaled up 2.4×) -->
                                        <Viewbox Width="67" Height="60" HorizontalAlignment="Center">
                                            <Viewbox.RenderTransform>
                                                <ScaleTransform x:Name="ColUnicornScale" CenterX="33.5" CenterY="30"/>
                                            </Viewbox.RenderTransform>
                                            <Viewbox.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                            <DoubleAnimation Storyboard.TargetName="ColUnicornScale"
                                                                             Storyboard.TargetProperty="ScaleX"
                                                                             From="1" To="1.2" Duration="0:0:0.7"/>
                                                            <DoubleAnimation Storyboard.TargetName="ColUnicornScale"
                                                                             Storyboard.TargetProperty="ScaleY"
                                                                             From="1" To="1.2" Duration="0:0:0.7"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Viewbox.Triggers>
                                            <Canvas Width="67" Height="60">
                                                <!-- Tail -->
                                                <Ellipse Canvas.Left="-2"  Canvas.Top="22" Width="14" Height="9"  Fill="#E040B0"/>
                                                <Ellipse Canvas.Left="-5"  Canvas.Top="29" Width="12" Height="12" Fill="#C02090"/>
                                                <Ellipse Canvas.Left="-3"  Canvas.Top="39" Width="11" Height="9"  Fill="#E040B0"/>
                                                <!-- Body -->
                                                <Ellipse Canvas.Left="5"   Canvas.Top="22" Width="46" Height="26" Fill="#FFB6C8"/>
                                                <!-- Neck -->
                                                <Polygon Points="43,48 55,48 53,22 46,22" Fill="#FFB6C8"/>
                                                <!-- Head -->
                                                <Ellipse Canvas.Left="41"  Canvas.Top="7"  Width="26" Height="22" Fill="#FFB6C8"/>
                                                <!-- Ear -->
                                                <Polygon Points="48,7 55,7 51.5,0"         Fill="#FFB6C8"/>
                                                <Polygon Points="49,7 54,7 51.5,2.8"        Fill="#F090B0"/>
                                                <!-- Horn (gold) -->
                                                <Polygon Points="53,7 60,7 56.5,-10"        Fill="#FFD700"/>
                                                <Polygon Points="55,7 58.5,7 56.5,-6"       Fill="#FFF5A0" Opacity="0.78"/>
                                                <!-- Mane -->
                                                <Ellipse Canvas.Left="36"  Canvas.Top="5"  Width="12" Height="12" Fill="#E040B0"/>
                                                <Ellipse Canvas.Left="34"  Canvas.Top="14" Width="12" Height="12" Fill="#C02090"/>
                                                <Ellipse Canvas.Left="34"  Canvas.Top="24" Width="10" Height="12" Fill="#E040B0"/>
                                                <!-- Legs -->
                                                <Rectangle Canvas.Left="9"  Canvas.Top="44" Width="7" Height="12" Fill="#F8A0BC" RadiusX="2" RadiusY="2"/>
                                                <Rectangle Canvas.Left="20" Canvas.Top="44" Width="7" Height="12" Fill="#F8A0BC" RadiusX="2" RadiusY="2"/>
                                                <Rectangle Canvas.Left="33" Canvas.Top="44" Width="7" Height="12" Fill="#F8A0BC" RadiusX="2" RadiusY="2"/>
                                                <Rectangle Canvas.Left="44" Canvas.Top="44" Width="7" Height="12" Fill="#F8A0BC" RadiusX="2" RadiusY="2"/>
                                                <!-- Hooves -->
                                                <Rectangle Canvas.Left="9"  Canvas.Top="53" Width="7" Height="7"  Fill="#B030A0" RadiusX="2" RadiusY="2"/>
                                                <Rectangle Canvas.Left="20" Canvas.Top="53" Width="7" Height="7"  Fill="#B030A0" RadiusX="2" RadiusY="2"/>
                                                <Rectangle Canvas.Left="33" Canvas.Top="53" Width="7" Height="7"  Fill="#B030A0" RadiusX="2" RadiusY="2"/>
                                                <Rectangle Canvas.Left="44" Canvas.Top="53" Width="7" Height="7"  Fill="#B030A0" RadiusX="2" RadiusY="2"/>
                                                <!-- Eye + shine -->
                                                <Ellipse Canvas.Left="60"   Canvas.Top="14" Width="6"  Height="6"  Fill="#222222"/>
                                                <Ellipse Canvas.Left="61.5" Canvas.Top="15" Width="2.5" Height="2.5" Fill="White"/>
                                            </Canvas>
                                        </Viewbox>

                                        <TextBlock Text="Done!"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

        </DockPanel>

        <!-- ═══════════════════════════════════════════════════════════════
             VICTORY OVERLAY — shown when all blocks are unicorned
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsGameWon, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="200">

            <!-- Dark magical background -->
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0.6,1">
                        <GradientStop Color="#E8180838" Offset="0"/>
                        <GradientStop Color="#E8340060" Offset="0.5"/>
                        <GradientStop Color="#E8200050" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ── Confetti (18 pieces looping forever, staggered starts) ── -->
            <!-- Each piece: HorizontalAlignment=Left + Margin positions it horizontally;
                 TranslateTransform.Y animates it from -20 → 720 in a loop. -->

            <Rectangle HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,0,0,0"
                       Width="10" Height="14" Fill="#FF4040" Opacity="0.90">
                <Rectangle.RenderTransform><TranslateTransform x:Name="C01" Y="-20"/></Rectangle.RenderTransform>
                <Rectangle.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0">
                        <DoubleAnimation Storyboard.TargetName="C01" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:2.4"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Rectangle.Triggers>
            </Rectangle>

            <Ellipse HorizontalAlignment="Left" VerticalAlignment="Top" Margin="100,0,0,0"
                     Width="11" Height="11" Fill="#FFD700" Opacity="0.92">
                <Ellipse.RenderTransform><TranslateTransform x:Name="C02" Y="-20"/></Ellipse.RenderTransform>
                <Ellipse.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.5">
                        <DoubleAnimation Storyboard.TargetName="C02" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:3.0"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Ellipse.Triggers>
            </Ellipse>

            <Rectangle HorizontalAlignment="Left" VerticalAlignment="Top" Margin="165,0,0,0"
                       Width="8" Height="13" Fill="#40C040" Opacity="0.88">
                <Rectangle.RenderTransform><TranslateTransform x:Name="C03" Y="-20"/></Rectangle.RenderTransform>
                <Rectangle.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:1.0">
                        <DoubleAnimation Storyboard.TargetName="C03" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:2.7"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Rectangle.Triggers>
            </Rectangle>

            <Ellipse HorizontalAlignment="Left" VerticalAlignment="Top" Margin="230,0,0,0"
                     Width="13" Height="9" Fill="#4080FF" Opacity="0.90">
                <Ellipse.RenderTransform><TranslateTransform x:Name="C04" Y="-20"/></Ellipse.RenderTransform>
                <Ellipse.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.2">
                        <DoubleAnimation Storyboard.TargetName="C04" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:3.3"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Ellipse.Triggers>
            </Ellipse>

            <Rectangle HorizontalAlignment="Left" VerticalAlignment="Top" Margin="290,0,0,0"
                       Width="9" Height="12" Fill="#FF40B0" Opacity="0.92">
                <Rectangle.RenderTransform><TranslateTransform x:Name="C05" Y="-20"/></Rectangle.RenderTransform>
                <Rectangle.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.7">
                        <DoubleAnimation Storyboard.TargetName="C05" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:2.1"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Rectangle.Triggers>
            </Rectangle>

            <Ellipse HorizontalAlignment="Left" VerticalAlignment="Top" Margin="350,0,0,0"
                     Width="12" Height="12" Fill="#FF8800" Opacity="0.88">
                <Ellipse.RenderTransform><TranslateTransform x:Name="C06" Y="-20"/></Ellipse.RenderTransform>
                <Ellipse.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:1.3">
                        <DoubleAnimation Storyboard.TargetName="C06" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:3.6"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Ellipse.Triggers>
            </Ellipse>

            <Rectangle HorizontalAlignment="Left" VerticalAlignment="Top" Margin="415,0,0,0"
                       Width="10" Height="14" Fill="#9B40FF" Opacity="0.90">
                <Rectangle.RenderTransform><TranslateTransform x:Name="C07" Y="-20"/></Rectangle.RenderTransform>
                <Rectangle.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.4">
                        <DoubleAnimation Storyboard.TargetName="C07" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:2.8"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Rectangle.Triggers>
            </Rectangle>

            <Ellipse HorizontalAlignment="Left" VerticalAlignment="Top" Margin="475,0,0,0"
                     Width="10" Height="10" Fill="#40C0FF" Opacity="0.92">
                <Ellipse.RenderTransform><TranslateTransform x:Name="C08" Y="-20"/></Ellipse.RenderTransform>
                <Ellipse.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.9">
                        <DoubleAnimation Storyboard.TargetName="C08" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:2.2"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Ellipse.Triggers>
            </Ellipse>

            <Rectangle HorizontalAlignment="Left" VerticalAlignment="Top" Margin="535,0,0,0"
                       Width="12" Height="10" Fill="#FF6060" Opacity="0.88">
                <Rectangle.RenderTransform><TranslateTransform x:Name="C09" Y="-20"/></Rectangle.RenderTransform>
                <Rectangle.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:1.5">
                        <DoubleAnimation Storyboard.TargetName="C09" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:3.1"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Rectangle.Triggers>
            </Rectangle>

            <Ellipse HorizontalAlignment="Left" VerticalAlignment="Top" Margin="595,0,0,0"
                     Width="11" Height="13" Fill="#60FF60" Opacity="0.85">
                <Ellipse.RenderTransform><TranslateTransform x:Name="C10" Y="-20"/></Ellipse.RenderTransform>
                <Ellipse.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.3">
                        <DoubleAnimation Storyboard.TargetName="C10" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:2.5"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Ellipse.Triggers>
            </Ellipse>

            <Rectangle HorizontalAlignment="Left" VerticalAlignment="Top" Margin="650,0,0,0"
                       Width="8" Height="15" Fill="#FFB040" Opacity="0.92">
                <Rectangle.RenderTransform><TranslateTransform x:Name="C11" Y="-20"/></Rectangle.RenderTransform>
                <Rectangle.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.8">
                        <DoubleAnimation Storyboard.TargetName="C11" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:3.4"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Rectangle.Triggers>
            </Rectangle>

            <Ellipse HorizontalAlignment="Left" VerticalAlignment="Top" Margin="710,0,0,0"
                     Width="13" Height="10" Fill="#FF4080" Opacity="0.90">
                <Ellipse.RenderTransform><TranslateTransform x:Name="C12" Y="-20"/></Ellipse.RenderTransform>
                <Ellipse.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:1.4">
                        <DoubleAnimation Storyboard.TargetName="C12" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:2.9"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Ellipse.Triggers>
            </Ellipse>

            <Rectangle HorizontalAlignment="Left" VerticalAlignment="Top" Margin="770,0,0,0"
                       Width="9" Height="13" Fill="#60A0FF" Opacity="0.88">
                <Rectangle.RenderTransform><TranslateTransform x:Name="C13" Y="-20"/></Rectangle.RenderTransform>
                <Rectangle.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.6">
                        <DoubleAnimation Storyboard.TargetName="C13" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:2.3"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Rectangle.Triggers>
            </Rectangle>

            <Ellipse HorizontalAlignment="Left" VerticalAlignment="Top" Margin="830,0,0,0"
                     Width="12" Height="10" Fill="#C040FF" Opacity="0.90">
                <Ellipse.RenderTransform><TranslateTransform x:Name="C14" Y="-20"/></Ellipse.RenderTransform>
                <Ellipse.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:1.1">
                        <DoubleAnimation Storyboard.TargetName="C14" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:3.7"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Ellipse.Triggers>
            </Ellipse>

            <Rectangle HorizontalAlignment="Left" VerticalAlignment="Top" Margin="885,0,0,0"
                       Width="10" Height="12" Fill="#FF6000" Opacity="0.88">
                <Rectangle.RenderTransform><TranslateTransform x:Name="C15" Y="-20"/></Rectangle.RenderTransform>
                <Rectangle.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.2">
                        <DoubleAnimation Storyboard.TargetName="C15" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:2.6"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Rectangle.Triggers>
            </Rectangle>

            <!-- Extra pieces to fill mid-screen gaps -->
            <Ellipse HorizontalAlignment="Left" VerticalAlignment="Top" Margin="65,0,0,0"
                     Width="9" Height="9" Fill="#FF80C0" Opacity="0.85">
                <Ellipse.RenderTransform><TranslateTransform x:Name="C16" Y="-20"/></Ellipse.RenderTransform>
                <Ellipse.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:1.7">
                        <DoubleAnimation Storyboard.TargetName="C16" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:3.2"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Ellipse.Triggers>
            </Ellipse>

            <Rectangle HorizontalAlignment="Left" VerticalAlignment="Top" Margin="500,0,0,0"
                       Width="11" Height="9" Fill="#00E0C0" Opacity="0.88">
                <Rectangle.RenderTransform><TranslateTransform x:Name="C17" Y="-20"/></Rectangle.RenderTransform>
                <Rectangle.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.35">
                        <DoubleAnimation Storyboard.TargetName="C17" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:2.15"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Rectangle.Triggers>
            </Rectangle>

            <Ellipse HorizontalAlignment="Left" VerticalAlignment="Top" Margin="750,0,0,0"
                     Width="10" Height="12" Fill="#FFE040" Opacity="0.90">
                <Ellipse.RenderTransform><TranslateTransform x:Name="C18" Y="-20"/></Ellipse.RenderTransform>
                <Ellipse.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.65">
                        <DoubleAnimation Storyboard.TargetName="C18" Storyboard.TargetProperty="Y" From="-20" To="720" Duration="0:0:3.85"/>
                    </Storyboard>
                </BeginStoryboard></EventTrigger></Ellipse.Triggers>
            </Ellipse>

            <!-- ── Victory card — pops in with elastic scale ── -->
            <Border x:Name="WinCard"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="24"
                    Padding="48,32"
                    MaxWidth="500"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="WinCardScale"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect Color="#60000030" BlurRadius="40" ShadowDepth="0"/>
                </Border.Effect>

                <StackPanel HorizontalAlignment="Center">

                    <!-- Large bouncing unicorn -->
                    <Viewbox Width="130" Height="116" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Viewbox.RenderTransform>
                            <ScaleTransform x:Name="WinUnicornScale" CenterX="65" CenterY="58"/>
                        </Viewbox.RenderTransform>
                        <Viewbox.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="WinUnicornScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         From="1" To="1.12" Duration="0:0:0.6"/>
                                        <DoubleAnimation Storyboard.TargetName="WinUnicornScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         From="1" To="1.12" Duration="0:0:0.6"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Viewbox.Triggers>
                        <Canvas Width="130" Height="116">
                            <!-- Tail -->
                            <Ellipse Canvas.Left="-4"  Canvas.Top="42" Width="27" Height="18" Fill="#E040B0"/>
                            <Ellipse Canvas.Left="-10" Canvas.Top="56" Width="23" Height="23" Fill="#C02090"/>
                            <Ellipse Canvas.Left="-6"  Canvas.Top="75" Width="21" Height="17" Fill="#E040B0"/>
                            <!-- Body -->
                            <Ellipse Canvas.Left="9"   Canvas.Top="42" Width="89" Height="51" Fill="#FFB6C8"/>
                            <!-- Neck -->
                            <Polygon Points="83,93 106,93 102,42 89,42" Fill="#FFB6C8"/>
                            <!-- Head -->
                            <Ellipse Canvas.Left="79"  Canvas.Top="13" Width="51" Height="42" Fill="#FFB6C8"/>
                            <!-- Ear -->
                            <Polygon Points="93,13 107,13 100,0"         Fill="#FFB6C8"/>
                            <Polygon Points="94,13 105,13 100,5"         Fill="#F090B0"/>
                            <!-- Horn (gold) -->
                            <Polygon Points="102,13 116,13 109,-20"      Fill="#FFD700"/>
                            <Polygon Points="106,13 113,13 109,-12"      Fill="#FFF5A0" Opacity="0.78"/>
                            <!-- Mane -->
                            <Ellipse Canvas.Left="70"  Canvas.Top="10"  Width="23" Height="23" Fill="#E040B0"/>
                            <Ellipse Canvas.Left="66"  Canvas.Top="27"  Width="23" Height="23" Fill="#C02090"/>
                            <Ellipse Canvas.Left="65"  Canvas.Top="46"  Width="20" Height="23" Fill="#E040B0"/>
                            <!-- Legs -->
                            <Rectangle Canvas.Left="18"  Canvas.Top="85" Width="13" Height="24" Fill="#F8A0BC" RadiusX="4" RadiusY="4"/>
                            <Rectangle Canvas.Left="38"  Canvas.Top="85" Width="13" Height="24" Fill="#F8A0BC" RadiusX="4" RadiusY="4"/>
                            <Rectangle Canvas.Left="64"  Canvas.Top="85" Width="13" Height="24" Fill="#F8A0BC" RadiusX="4" RadiusY="4"/>
                            <Rectangle Canvas.Left="84"  Canvas.Top="85" Width="13" Height="24" Fill="#F8A0BC" RadiusX="4" RadiusY="4"/>
                            <!-- Hooves -->
                            <Rectangle Canvas.Left="18"  Canvas.Top="102" Width="13" Height="14" Fill="#B030A0" RadiusX="4" RadiusY="4"/>
                            <Rectangle Canvas.Left="38"  Canvas.Top="102" Width="13" Height="14" Fill="#B030A0" RadiusX="4" RadiusY="4"/>
                            <Rectangle Canvas.Left="64"  Canvas.Top="102" Width="13" Height="14" Fill="#B030A0" RadiusX="4" RadiusY="4"/>
                            <Rectangle Canvas.Left="84"  Canvas.Top="102" Width="13" Height="14" Fill="#B030A0" RadiusX="4" RadiusY="4"/>
                            <!-- Eye + shine -->
                            <Ellipse Canvas.Left="116"  Canvas.Top="27" Width="11" Height="11" Fill="#222222"/>
                            <Ellipse Canvas.Left="118"  Canvas.Top="29" Width="5"  Height="5"  Fill="White"/>
                        </Canvas>
                    </Viewbox>

                    <!-- "YOU DID IT!" — rainbow gradient text -->
                    <TextBlock FontSize="40" FontWeight="Black"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4040" Offset="0.0"/>
                                <GradientStop Color="#FF9900" Offset="0.25"/>
                                <GradientStop Color="#40C040" Offset="0.55"/>
                                <GradientStop Color="#6040FF" Offset="0.80"/>
                                <GradientStop Color="#FF40B0" Offset="1.0"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                        YOU DID IT! 🦄
                    </TextBlock>

                    <!-- Subtitle -->
                    <TextBlock Text="All blocks unicorned! You're a Math Champion! 🌈"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#5B2D8E"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,18"/>

                    <!-- Time display -->
                    <Border Background="#F0E8FF" CornerRadius="12" Padding="20,10" Margin="0,0,0,16"
                            HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏱  Your time: "
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="#5B2D8E"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding FinalTime}"
                                       FontSize="28" FontWeight="Black"
                                       Foreground="#9B40FF"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Name entry for leaderboard ── -->
                    <Border Background="#F5EEFF" CornerRadius="14" Padding="18,12" Margin="0,0,0,18"
                            HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Save your time to the leaderboard:"
                                       FontSize="13" Foreground="#5B2D8E" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBox Text="{Binding PlayerName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="16" Width="200" Padding="7,5"
                                         BorderBrush="#9B59B6" BorderThickness="2"
                                         VerticalContentAlignment="Center"
                                         MaxLength="20">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsScoreSaved}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <Button Content="Save Score"
                                        Command="{Binding SaveScoreCommand}"
                                        Style="{StaticResource PillButton}"
                                        Background="#F5A623"
                                        FontSize="13"
                                        Padding="14,7"
                                        Margin="8,0,0,0"/>
                            </StackPanel>
                            <!-- Saved confirmation -->
                            <TextBlock Text="{Binding SavedScoreMessage}"
                                       FontSize="13" FontWeight="Bold" Foreground="#5CB85C"
                                       HorizontalAlignment="Center" Margin="0,7,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsScoreSaved}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Back to Puzzles"
                                Command="{Binding BackCommand}"
                                Style="{StaticResource PillButton}"
                                Background="#9B59B6"
                                FontSize="16"
                                Padding="22,10"/>
                    </StackPanel>

                </StackPanel>
            </Border>

        </Grid>
        <!-- End victory overlay -->

        <!-- ═══════════════════════════════════════════════════════════════
             FAIL OVERLAY — shown when all questions answered but not all correct
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsGameFailed, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="200">

            <!-- Dark red background -->
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0.6,1">
                        <GradientStop Color="#E8380808" Offset="0"/>
                        <GradientStop Color="#E8600010" Offset="0.5"/>
                        <GradientStop Color="#E8400008" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ── Fail card ── -->
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="24"
                    Padding="48,32"
                    MaxWidth="500"
                    RenderTransformOrigin="0.5,0.5">
                <Border.Effect>
                    <DropShadowEffect Color="#60300000" BlurRadius="40" ShadowDepth="0"/>
                </Border.Effect>

                <StackPanel HorizontalAlignment="Center">

                    <!-- Sad face emoji -->
                    <TextBlock Text="😢"
                               FontSize="80"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <!-- "SO CLOSE!" heading -->
                    <TextBlock FontSize="40" FontWeight="Black"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#CC2020" Offset="0.0"/>
                                <GradientStop Color="#FF6020" Offset="0.5"/>
                                <GradientStop Color="#CC2020" Offset="1.0"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                        SO CLOSE!
                    </TextBlock>

                    <!-- Subtitle -->
                    <TextBlock Text="Some answers were wrong. Try again to get a perfect score!"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#7B2020"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,18"/>

                    <!-- Score display -->
                    <Border Background="#FFF0F0" CornerRadius="12" Padding="20,10" Margin="0,0,0,10"
                            HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⭐  Score: "
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="#7B2020"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ScoreText}"
                                       FontSize="28" FontWeight="Black"
                                       Foreground="#CC2020"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Time display -->
                    <Border Background="#FFF0F0" CornerRadius="12" Padding="20,10" Margin="0,0,0,22"
                            HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏱  Your time: "
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="#7B2020"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding FinalTime}"
                                       FontSize="28" FontWeight="Black"
                                       Foreground="#CC2020"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="🎮  Try Again"
                                Command="{Binding PlayAgainCommand}"
                                Style="{StaticResource PillButton}"
                                Background="#CC3030"
                                FontSize="16"
                                Padding="22,10"
                                Margin="0,0,14,0"/>
                        <Button Content="Main Menu"
                                Command="{Binding BackCommand}"
                                Style="{StaticResource PillButton}"
                                Background="#7B2020"
                                FontSize="16"
                                Padding="22,10"/>
                    </StackPanel>

                </StackPanel>
            </Border>

        </Grid>
        <!-- End fail overlay -->

    </Grid>
</UserControl>
