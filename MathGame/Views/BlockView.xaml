<UserControl x:Class="MathGame.Views.BlockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Question tile style -->
        <Style x:Key="QuestionTile" TargetType="Border">
            <Setter Property="Margin"        Value="6"/>
            <Setter Property="CornerRadius"  Value="12"/>
            <Setter Property="MinWidth"      Value="148"/>
            <Setter Property="MinHeight"     Value="72"/>
        </Style>

        <!-- Rounded pill button -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Foreground"     Value="White"/>
            <Setter Property="FontSize"       Value="16"/>
            <Setter Property="FontWeight"     Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="Padding"        Value="24,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"  Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                            <Trigger Property="IsPressed"    Value="True"><Setter Property="Opacity" Value="0.70"/></Trigger>
                            <Trigger Property="IsEnabled"    Value="False"><Setter Property="Opacity" Value="0.40"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Root grid; unicorn overlay sits on top when complete -->
    <Grid>

        <!-- ── Main game area ── -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title row -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="← Back"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource PillButton}"
                        Background="#9B59B6"
                        Padding="14,8"
                        FontSize="13"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Title}"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#5B2D8E"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Question tiles: 5 columns × 2 rows -->
            <ItemsControl Grid.Row="1"
                          ItemsSource="{Binding Questions}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="2" Columns="5"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource QuestionTile}"
                                Background="{Binding Background}">
                            <Border.Effect>
                                <DropShadowEffect Color="#30000000" BlurRadius="6" ShadowDepth="2"/>
                            </Border.Effect>
                            <TextBlock Text="{Binding DisplayText}"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{Binding Foreground}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Input row -->
            <Grid Grid.Row="2" Margin="0,20,0,0" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Answer:"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="#5B2D8E"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>

                <TextBox Grid.Column="1"
                         x:Name="AnswerBox"
                         Text="{Binding PlayerInput, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="22" FontWeight="Bold"
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center"
                         Height="44"
                         BorderBrush="#9B59B6"
                         BorderThickness="2"
                         Padding="4">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SubmitCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <Button Grid.Column="2"
                        Content="Check ✓"
                        Command="{Binding SubmitCommand}"
                        Style="{StaticResource PillButton}"
                        Background="#5CB85C"
                        Margin="12,0,0,0"/>
            </Grid>

            <!-- Feedback / status row -->
            <TextBlock Grid.Row="3"
                       Text="{Binding FeedbackMessage}"
                       FontSize="18" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0"
                       Foreground="#444"/>

            <!-- "All answered but not perfect" notice -->
            <Border Grid.Row="3"
                    Visibility="{Binding IsAllAnswered, Converter={StaticResource BoolToVis}}"
                    Background="#FFF3CD"
                    CornerRadius="10"
                    Padding="20,10"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center">
                <TextBlock Text="{Binding FinishedMessage}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#856404"/>
            </Border>
        </Grid>

        <!-- ── Unicorn overlay (all 10 correct) ── -->
        <Grid Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"
              Background="#CC000000">
            <Border Background="White"
                    CornerRadius="24"
                    Padding="40,32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="500">
                <Border.Effect>
                    <DropShadowEffect Color="#80000000" BlurRadius="24" ShadowDepth="0"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">

                    <!-- Animated unicorn emoji -->
                    <TextBlock Text="🦄"
                               FontSize="108"
                               HorizontalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <ScaleTransform x:Name="UnicornScale" ScaleX="1" ScaleY="1"
                                            CenterX="54" CenterY="54"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="UnicornScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         From="1" To="1.15" Duration="0:0:0.7"/>
                                        <DoubleAnimation Storyboard.TargetName="UnicornScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         From="1" To="1.15" Duration="0:0:0.7"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>

                    <TextBlock Text="🌟  PERFECT!  🌟"
                               FontSize="36" FontWeight="Bold"
                               Foreground="#9B59B6"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,4"/>

                    <TextBlock Text="All 10 correct — Block complete!"
                               FontSize="20"
                               Foreground="#5B2D8E"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24"/>

                    <Button Content="← Back to blocks"
                            Command="{Binding BackCommand}"
                            Style="{StaticResource PillButton}"
                            Background="#9B59B6"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
